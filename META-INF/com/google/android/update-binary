#!/sbin/sh

umask 022

ui_print() { echo "$1"; }

require_new_magisk() {
  ui_print "*******************************"
  ui_print " Please install Magisk v24.0+ "
  ui_print "*******************************"
  exit 1
}

OUTFD=$2
ZIPFILE=$3

mount /data 2>/dev/null

if [ -f /data/adb/magisk/util_functions.sh ]; then
  . /data/adb/magisk/util_functions.sh
  install_module
  exit 0
fi

if [ -f /data/adb/ksu/bin/util_functions.sh ]; then
  . /data/adb/ksu/bin/util_functions.sh
  install_module
  exit 0
fi

if [ -f /data/adb/ap/bin/util_functions.sh ]; then
  . /data/adb/ap/bin/util_functions.sh
  install_module
  exit 0
fi

require_new_magisk
